#!/bin/bash
# keys/secrets/encrypt_secrets.sh

# تشفير جميع الأسرار
encrypt_secret() {
    SECRET_FILE=$1
    RECIPIENT="security@hostingsystem.com"
    
    if [ -f "$SECRET_FILE" ]; then
        # تشفير باستخدام GPG
        gpg --encrypt \
            --recipient "$RECIPIENT" \
            --armor \
            --output "$SECRET_FILE.gpg" \
            "$SECRET_FILE"
        
        # حذف الملف الأصلي
        shred -u "$SECRET_FILE"
        
        # تسجيل العملية
        echo "$(date): Encrypted $SECRET_FILE" >> /var/log/secret_rotation.log
    fi
}

# تشفير جميع الملفات في المجلد
find /etc/hosting/secrets/ -type f -name "*.secret" -o -name "*.password" -o -name "*.key" | while read file; do
    encrypt_secret "$file"
done

# إنشاء ملف vault مشفر يحتوي على جميع الأسرار
tar -czf - /etc/hosting/secrets/ | gpg --encrypt --recipient "security@hostingsystem.com" --output /etc/hosting/secrets/vault.tar.gz.gpg